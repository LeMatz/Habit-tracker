{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "noEmit": true
  },
  "include": [
    "types.ts",
    "constants.tsx",
    "index.ts",
    "App.tsx",
    "components",
    "screens",
    "services",
    "context",
    "utils",
    "nativewind-env.d.ts"
  ]
}
